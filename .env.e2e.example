# =============================================================================
# E2E test configuration (copy to .env.e2e.local)
# =============================================================================
# These tests run against your local dev server + Supabase project.
# Use a dedicated staging/test Supabase project when possible.
# Never point destructive tests at production customer stores.

# App URL (optional — default http://localhost:3000)
PLAYWRIGHT_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Public signup test — no extra config required
# Creates a pending_signups row with a unique @menuqr-e2e.test email
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Admin tests (required for admin-signups.spec.ts)
# -----------------------------------------------------------------------------
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=your-admin-password

# Approve flow is OFF by default (creates auth user + store in Supabase)
# Set to true only on a test/staging database
E2E_ALLOW_SIGNUP_APPROVE=false

# Optional: approve an existing pending signup by email instead of creating one
# E2E_APPROVE_SIGNUP_EMAIL=e2e-approve-123@menuqr-e2e.test

# -----------------------------------------------------------------------------
# Owner dashboard tests (required for owner-dashboard.spec.ts)
# Use a dedicated test store owner — NOT a real customer account
# -----------------------------------------------------------------------------
E2E_OWNER_EMAIL=owner@e2e-test.example
E2E_OWNER_PASSWORD=your-owner-password

# Optional: verify changes on the public menu
E2E_TEST_STORE_SLUG=your-e2e-test-store
