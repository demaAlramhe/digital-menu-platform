# =============================================================================
# Supabase (required)
# =============================================================================
# Project URL from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — safe in the browser; used by middleware and client auth
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server only; never expose to the client or commit real values
# Used for admin API routes, public storefront reads, and owner dashboard writes
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Site URL (recommended for production)
# =============================================================================
# Canonical origin for QR codes and public links (no trailing slash)
# Example: https://menu.yourdomain.com
# If unset, the app derives the origin from request headers (fine for local dev)
NEXT_PUBLIC_SITE_URL=

# Business WhatsApp for signup confirmation (digits only, no + prefix)
# Example: 972543223106
NEXT_PUBLIC_BUSINESS_WHATSAPP=972543223106

# =============================================================================
# Cloudinary (required for image uploads in dashboard)
# =============================================================================
# From Cloudinary console → Settings → Access keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================================================
# OpenAI — optional, enables auto-translation on save (ar / he / en)
# =============================================================================
# Without OPENAI_API_KEY, content is saved in the owner's source language only
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# Local development
# =============================================================================
# 1. Copy this file to .env.local and fill in values
# 2. npm install && npm run dev
# 3. Run SQL migrations — see supabase/README.md
